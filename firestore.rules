rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "dev.lucas.rafael@gmail.com";
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "dev.lucas.rafael@gmail.com";
    }
  }
}
